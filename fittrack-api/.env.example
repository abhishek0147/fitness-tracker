# Firebase Configuration
FIREBASE_PROJECT_ID=fitness-tracking-d01f6
FIREBASE_DATABASE_URL=https://fitness-tracking-d01f6.firebaseio.com

# Firebase Admin SDK Service Account (from Firebase Console -> Project Settings -> Service Accounts)
# Download JSON from Firebase Console and stringify it
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"fitness-tracking-d01f6","private_key":"...","client_email":"..."}

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=./fittrack.db

# Frontend URLs
FRONTEND_URL=http://localhost:8080
